<Window x:Class="NetSniffer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:NetSniffer"
        xmlns:vm="clr-namespace:NetSniffer.ViewModels"
        xmlns:conv="clr-namespace:NetSniffer.Converters"
        Title="NetSniffer" Height="750" Width="1400"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <conv:StateColorConverter x:Key="StateColorConverter"/>
        <conv:ProtocolColorConverter x:Key="ProtocolColorConverter"/>
        <conv:RiskColorConverter x:Key="RiskColorConverter"/>
        <conv:RiskBadgeColorConverter x:Key="RiskBadgeColorConverter"/>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <conv:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
        <conv:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter"/>

        <!-- Scrollbar Style -->
        <Style x:Key="DarkScrollBar" TargetType="ScrollBar">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Width" Value="6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="Transparent">
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Rectangle Fill="#3A3A4A" RadiusX="3" RadiusY="3"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DarkScrollViewer" TargetType="ScrollViewer">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollViewer">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition Width="6"/>
                            </Grid.ColumnDefinitions>
                            <ScrollContentPresenter Grid.Column="0"/>
                            <ScrollBar Grid.Column="1" Style="{StaticResource DarkScrollBar}"
                                       Orientation="Vertical"
                                       Value="{TemplateBinding VerticalOffset}"
                                       Maximum="{TemplateBinding ScrollableHeight}"
                                       ViewportSize="{TemplateBinding ViewportHeight}"
                                       Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ListBox Item Style -->
        <Style x:Key="ConnectionItemStyle" TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#C8C8D4"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="ItemBorder" Background="Transparent"
                                BorderThickness="0,0,0,1"
                                BorderBrush="#1E1E2A">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#1A2A3A"/>
                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="#2A4A6A"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#16202A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Filter Button Style -->
        <Style x:Key="FilterButtonStyle" TargetType="RadioButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#8888A0"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="12,5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="14" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#3D7EFF"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#252535"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Action Button Style -->
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#252535"/>
            <Setter Property="Foreground" Value="#A0A0B8"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#333348"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2E2E45"/>
                                <Setter Property="Foreground" Value="#D0D0E8"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#1A1A2A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Primary Button Style -->
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#3D7EFF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontFamily" Value="Segoe UI Semibold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#5590FF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#2A60CC"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Danger Button Style -->
        <Style x:Key="DangerButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Background" Value="#CC3333"/>
        </Style>

        <!-- TextBox Style -->
        <Style x:Key="SearchBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="#1A1A28"/>
            <Setter Property="Foreground" Value="#C0C0D8"/>
            <Setter Property="CaretBrush" Value="#3D7EFF"/>
            <Setter Property="BorderBrush" Value="#2A2A3A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <Grid>
                                <TextBlock x:Name="Placeholder" Text="Search by process, port, address..."
                                           Foreground="#44445A" FontFamily="Segoe UI" FontSize="12"
                                           VerticalAlignment="Center" Margin="10,0,0,0"
                                           Visibility="Collapsed"/>
                                <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"
                                              VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Text" Value="">
                                <Setter TargetName="Placeholder" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#3D7EFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Border CornerRadius="10" Background="#12121E"
            BorderBrush="#252535" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="30" ShadowDepth="0" Color="#000000" Opacity="0.8"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="50"/>
                <!-- Title bar -->
                <RowDefinition Height="Auto"/>
                <!-- Stats bar -->
                <RowDefinition Height="Auto"/>
                <!-- Filter bar -->
                <RowDefinition Height="Auto"/>
                <!-- Column headers -->
                <RowDefinition Height="*"/>
                <!-- Content -->
                <RowDefinition Height="28"/>
                <!-- Status bar -->
            </Grid.RowDefinitions>

            <!-- ═══ TITLE BAR ═══ -->
            <Border Grid.Row="0" CornerRadius="10,10,0,0" Background="#0E0E1A"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid Margin="16,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Icon + Title -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <Image Source="pack://application:,,,/app.ico" Width="28" Height="28" Margin="0,0,10,0"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="NetSniffer" FontFamily="Segoe UI Semibold" FontSize="14"
                                       Foreground="#E0E0F0"/>
                            <TextBlock Text="Network Connection Monitor" FontFamily="Segoe UI" FontSize="10"
                                       Foreground="#44445A"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Search -->
                    <TextBox Grid.Column="2" Style="{StaticResource SearchBoxStyle}"
                             Width="300" Margin="0,0,12,0" VerticalAlignment="Center"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"/>

                    <!-- Scan Button -->
                    <Button Grid.Column="3" Style="{StaticResource PrimaryButtonStyle}"
                            Command="{Binding ScanCommand}" VerticalAlignment="Center"
                            Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⟳ " FontSize="13"/>
                            <TextBlock Text="Refresh"/>
                        </StackPanel>
                    </Button>

                    <!-- Window controls -->
                    <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center"
                                Margin="4,0,0,0">
                        <Button Content="─" Width="32" Height="32" Cursor="Hand"
                                Background="Transparent" Foreground="#555570"
                                BorderThickness="0" FontSize="14"
                                Click="MinimizeButton_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="Transparent" CornerRadius="4">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Foreground" Value="#C0C0D8"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button Content="□" Width="32" Height="32" Cursor="Hand"
                                Background="Transparent" Foreground="#555570"
                                BorderThickness="0" FontSize="12"
                                Click="MaximizeButton_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="Transparent" CornerRadius="4">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Foreground" Value="#C0C0D8"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button Content="✕" Width="32" Height="32" Cursor="Hand"
                                Background="Transparent" Foreground="#555570"
                                BorderThickness="0" FontSize="12"
                                Click="CloseButton_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Bd" Background="Transparent" CornerRadius="4">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#CC3333"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ═══ STATS BAR ═══ -->
            <Border Grid.Row="1" Background="#0E0E1A" Padding="16,12">
                <StackPanel Orientation="Horizontal">
                    <!-- Total Connections -->
                    <Border Background="#16162A" CornerRadius="6" Padding="14,10" Margin="0,0,10,0" MinWidth="110">
                        <StackPanel>
                            <TextBlock Text="TOTAL CONNECTIONS" FontFamily="Segoe UI" FontSize="9"
                                       Foreground="#44445A" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding TotalCount}" FontFamily="Segoe UI Semibold"
                                       FontSize="26" Foreground="#C8C8E0" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Established -->
                    <Border Background="#16162A" CornerRadius="6" Padding="14,10" Margin="0,0,10,0" MinWidth="110">
                        <StackPanel>
                            <TextBlock Text="ESTABLISHED" FontFamily="Segoe UI" FontSize="9"
                                       Foreground="#44445A" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding EstablishedCount}" FontFamily="Segoe UI Semibold"
                                       FontSize="26" Foreground="#3DCC6A" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Listening -->
                    <Border Background="#16162A" CornerRadius="6" Padding="14,10" Margin="0,0,10,0" MinWidth="110">
                        <StackPanel>
                            <TextBlock Text="LISTENING" FontFamily="Segoe UI" FontSize="9"
                                       Foreground="#44445A" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding ListeningCount}" FontFamily="Segoe UI Semibold"
                                       FontSize="26" Foreground="#4A9EFF" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Suspicious -->
                    <Border Background="#16162A" CornerRadius="6" Padding="14,10" Margin="0,0,10,0" MinWidth="110">
                        <StackPanel>
                            <TextBlock Text="SUSPICIOUS" FontFamily="Segoe UI" FontSize="9"
                                       Foreground="#44445A" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding SuspiciousCount}" FontFamily="Segoe UI Semibold"
                                       FontSize="26" Foreground="#FF4A4A" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Show Suspicious Button -->
                    <Button Style="{StaticResource DangerButtonStyle}" Margin="0,0,0,0"
                            Command="{Binding ShowSuspiciousCommand}"
                            VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⚠ " FontSize="13"/>
                            <TextBlock Text="Show Suspicious"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Border>

            <!-- ═══ FILTER BAR ═══ -->
            <Border Grid.Row="2" Background="#0E0E1A" Padding="16,8"
                    BorderThickness="0,1,0,0" BorderBrush="#1A1A2A">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="FILTER" FontFamily="Segoe UI" FontSize="10"
                               Foreground="#33334A" VerticalAlignment="Center"
                               Margin="0,0,12,0" FontWeight="SemiBold"/>
                    <RadioButton Style="{StaticResource FilterButtonStyle}" Content="All"
                                 GroupName="Filter" IsChecked="True"
                                 Command="{Binding FilterCommand}" CommandParameter="All"/>
                    <RadioButton Style="{StaticResource FilterButtonStyle}" Content="⚡ TCP"
                                 GroupName="Filter" Margin="4,0,0,0"
                                 Command="{Binding FilterCommand}" CommandParameter="TCP"/>
                    <RadioButton Style="{StaticResource FilterButtonStyle}" Content="◈ UDP"
                                 GroupName="Filter" Margin="4,0,0,0"
                                 Command="{Binding FilterCommand}" CommandParameter="UDP"/>
                    <RadioButton Style="{StaticResource FilterButtonStyle}" Content="● Established"
                                 GroupName="Filter" Margin="4,0,0,0"
                                 Command="{Binding FilterCommand}" CommandParameter="Established"/>
                    <RadioButton Style="{StaticResource FilterButtonStyle}" Content="◎ Listening"
                                 GroupName="Filter" Margin="4,0,0,0"
                                 Command="{Binding FilterCommand}" CommandParameter="Listening"/>
                </StackPanel>
            </Border>

            <!-- ═══ COLUMN HEADERS ═══ -->
            <Border Grid.Row="3" Background="#0A0A16"
                    BorderThickness="0,1,0,1" BorderBrush="#1A1A2A" Padding="12,7">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="70"/>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="60"/>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="60"/>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="PROCESS" Style="{StaticResource {x:Type TextBlock}}"
                               FontFamily="Segoe UI" FontSize="10" Foreground="#33334A" FontWeight="SemiBold"/>
                    <TextBlock Grid.Column="1" Text="PID"
                               FontFamily="Segoe UI" FontSize="10" Foreground="#33334A" FontWeight="SemiBold"/>
                    <TextBlock Grid.Column="2" Text="PROTOCOL"
                               FontFamily="Segoe UI" FontSize="10" Foreground="#33334A" FontWeight="SemiBold"/>
                    <TextBlock Grid.Column="3" Text="LOCAL ADDRESS"
                               FontFamily="Segoe UI" FontSize="10" Foreground="#33334A" FontWeight="SemiBold"/>
                    <TextBlock Grid.Column="4" Text="PORT"
                               FontFamily="Segoe UI" FontSize="10" Foreground="#33334A" FontWeight="SemiBold"/>
                    <TextBlock Grid.Column="5" Text="REMOTE ADDRESS"
                               FontFamily="Segoe UI" FontSize="10" Foreground="#33334A" FontWeight="SemiBold"/>
                    <TextBlock Grid.Column="6" Text="PORT"
                               FontFamily="Segoe UI" FontSize="10" Foreground="#33334A" FontWeight="SemiBold"/>
                    <TextBlock Grid.Column="7" Text="STATE"
                               FontFamily="Segoe UI" FontSize="10" Foreground="#33334A" FontWeight="SemiBold"/>
                    <TextBlock Grid.Column="8" Text="RISK"
                               FontFamily="Segoe UI" FontSize="10" Foreground="#33334A" FontWeight="SemiBold"/>
                </Grid>
            </Border>

            <!-- ═══ MAIN CONTENT ═══ -->
            <Grid Grid.Row="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="280"/>
                </Grid.ColumnDefinitions>

                <!-- Connection List -->
                <ListBox Grid.Column="0" Background="Transparent" BorderThickness="0"
                         ItemsSource="{Binding FilteredConnections}"
                         SelectedItem="{Binding SelectedConnection}"
                         ItemContainerStyle="{StaticResource ConnectionItemStyle}"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         VirtualizingPanel.IsVirtualizing="True"
                         VirtualizingPanel.VirtualizationMode="Recycling">
                    <ListBox.Template>
                        <ControlTemplate TargetType="ListBox">
                            <ScrollViewer Style="{StaticResource DarkScrollViewer}">
                                <ItemsPresenter/>
                            </ScrollViewer>
                        </ControlTemplate>
                    </ListBox.Template>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="12,9">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="180"/>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="60"/>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="60"/>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Process -->
                                <StackPanel Grid.Column="0" Orientation="Horizontal">
                                    <Border Width="16" Height="16" CornerRadius="3"
                                            Background="#1A2A3A" Margin="0,0,7,0">
                                        <TextBlock Text="▸" FontSize="8" Foreground="#3D7EFF"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="{Binding ProcessName}" FontFamily="Segoe UI" FontSize="12"
                                               Foreground="#C8C8D4" VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"/>
                                </StackPanel>

                                <!-- PID -->
                                <TextBlock Grid.Column="1" Text="{Binding Pid}" FontFamily="Consolas"
                                           FontSize="11" Foreground="#55556A" VerticalAlignment="Center"/>

                                <!-- Protocol -->
                                <Border Grid.Column="2" CornerRadius="3" Padding="5,2"
                                        Background="{Binding Protocol, Converter={StaticResource ProtocolColorConverter}}"
                                        HorizontalAlignment="Left" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Protocol}" FontFamily="Segoe UI Semibold"
                                               FontSize="10" Foreground="White"/>
                                </Border>

                                <!-- Local Address -->
                                <TextBlock Grid.Column="3" Text="{Binding LocalAddress}" FontFamily="Consolas"
                                           FontSize="11" Foreground="#8888A0" VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"/>

                                <!-- Local Port -->
                                <TextBlock Grid.Column="4" Text="{Binding LocalPort}" FontFamily="Consolas"
                                           FontSize="11" Foreground="#5A8ABF" VerticalAlignment="Center"/>

                                <!-- Remote Address -->
                                <TextBlock Grid.Column="5" Text="{Binding RemoteAddress}" FontFamily="Consolas"
                                           FontSize="11" Foreground="#8888A0" VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"/>

                                <!-- Remote Port -->
                                <TextBlock Grid.Column="6" Text="{Binding RemotePort}" FontFamily="Consolas"
                                           FontSize="11" Foreground="#5A8ABF" VerticalAlignment="Center"/>

                                <!-- State -->
                                <StackPanel Grid.Column="7" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Ellipse Width="7" Height="7" Margin="0,0,5,0"
                                             Fill="{Binding State, Converter={StaticResource StateColorConverter}}"/>
                                    <TextBlock Text="{Binding State}" FontFamily="Segoe UI" FontSize="11"
                                               Foreground="{Binding State, Converter={StaticResource StateColorConverter}}"/>
                                </StackPanel>

                                <!-- Risk -->
                                <Border Grid.Column="8" CornerRadius="3" Padding="7,2"
                                        Background="{Binding RiskLevel, Converter={StaticResource RiskBadgeColorConverter}}"
                                        HorizontalAlignment="Left" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding RiskLevel}" FontFamily="Segoe UI Semibold"
                                               FontSize="10"
                                               Foreground="{Binding RiskLevel, Converter={StaticResource RiskColorConverter}}"/>
                                </Border>
                            </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- Divider -->
                <Border Grid.Column="1" Width="1" Background="#1A1A2A"/>

                <!-- Detail Panel -->
                <Border Grid.Column="2" Background="#0E0E1A">
                    <!-- Empty state -->
                    <TextBlock Text="Select a connection&#10;to view details"
                               Visibility="{Binding SelectedConnection, Converter={StaticResource NullToVisibilityConverter}}"
                               FontFamily="Segoe UI" FontSize="13" Foreground="#2A2A3A"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               TextAlignment="Center"/>
                </Border>

                <!-- Detail Panel (populated) -->
                <Border Grid.Column="2" Background="#0E0E1A" Padding="16"
                        Visibility="{Binding SelectedConnection, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter=Inverse}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel DataContext="{Binding SelectedConnection}">
                            <!-- Risk Badge -->
                            <Border CornerRadius="6" Padding="12,8" Margin="0,0,0,14"
                                    Background="{Binding RiskLevel, Converter={StaticResource RiskBadgeColorConverter}}">
                                <StackPanel>
                                    <TextBlock Text="RISK LEVEL" FontFamily="Segoe UI" FontSize="9"
                                               Foreground="#44445A" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding RiskLevel}" FontFamily="Segoe UI Semibold"
                                               FontSize="22" Foreground="{Binding RiskLevel, Converter={StaticResource RiskColorConverter}}"
                                               Margin="0,2,0,0"/>
                                </StackPanel>
                            </Border>

                            <!-- Process Name -->
                            <TextBlock Text="{Binding ProcessName}" FontFamily="Segoe UI Semibold"
                                       FontSize="16" Foreground="#E0E0F0" Margin="0,0,0,2"/>
                            <TextBlock Text="{Binding ProcessPath}" FontFamily="Segoe UI" FontSize="11"
                                       Foreground="#44445A" TextWrapping="Wrap" Margin="0,0,0,14"/>

                            <!-- Details Grid -->
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="PID" FontFamily="Segoe UI" FontSize="11" Foreground="#44445A" Margin="0,4"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Pid}" FontFamily="Consolas" FontSize="11" Foreground="#8888A0" Margin="0,4"/>

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Protocol" FontFamily="Segoe UI" FontSize="11" Foreground="#44445A" Margin="0,4"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Protocol}" FontFamily="Segoe UI Semibold" FontSize="11"
                                           Foreground="{Binding Protocol, Converter={StaticResource ProtocolColorConverter}}" Margin="0,4"/>

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="State" FontFamily="Segoe UI" FontSize="11" Foreground="#44445A" Margin="0,4"/>
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding State}" FontFamily="Segoe UI Semibold" FontSize="11"
                                           Foreground="{Binding State, Converter={StaticResource StateColorConverter}}" Margin="0,4"/>

                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Local" FontFamily="Segoe UI" FontSize="11" Foreground="#44445A" Margin="0,4"/>
                                <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding LocalEndpoint}" FontFamily="Consolas" FontSize="11" Foreground="#8888A0" Margin="0,4" TextWrapping="Wrap"/>

                                <TextBlock Grid.Row="4" Grid.Column="0" Text="Remote" FontFamily="Segoe UI" FontSize="11" Foreground="#44445A" Margin="0,4"/>
                                <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding RemoteEndpoint}" FontFamily="Consolas" FontSize="11" Foreground="#8888A0" Margin="0,4" TextWrapping="Wrap"/>

                                <TextBlock Grid.Row="5" Grid.Column="0" Text="Location" FontFamily="Segoe UI" FontSize="11" Foreground="#44445A" Margin="0,4"/>
                                <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding RemoteLocation}" FontFamily="Segoe UI" FontSize="11" Foreground="#8888A0" Margin="0,4" TextWrapping="Wrap"/>

                                <TextBlock Grid.Row="6" Grid.Column="0" Text="Description" FontFamily="Segoe UI" FontSize="11" Foreground="#44445A" Margin="0,4"/>
                                <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding Description}" FontFamily="Segoe UI" FontSize="11" Foreground="#8888A0" Margin="0,4" TextWrapping="Wrap"/>
                            </Grid>

                            <!-- Separator -->
                            <Border Height="1" Background="#1A1A2A" Margin="0,10,0,10"/>

                            <!-- ACTIONS label -->
                            <TextBlock Text="ACTIONS" FontFamily="Segoe UI" FontSize="9"
                                       Foreground="#33334A" FontWeight="SemiBold" Margin="0,0,0,8"/>

                            <!-- Terminate Button -->
                            <Button Style="{StaticResource DangerButtonStyle}"
                                    Command="{Binding DataContext.TerminateCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                    HorizontalAlignment="Stretch" Margin="0,0,0,6">
                                <TextBlock Text="⊗  Terminate Process"/>
                            </Button>

                            <!-- Secondary actions -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="6"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0" Style="{StaticResource ActionButtonStyle}"
                                        Command="{Binding DataContext.OpenLocationCommand, RelativeSource={RelativeSource AncestorType=Window}}">
                                    <TextBlock Text="⬡  Open Location"/>
                                </Button>
                                <Button Grid.Column="2" Style="{StaticResource ActionButtonStyle}"
                                        Command="{Binding DataContext.CopyAddressCommand, RelativeSource={RelativeSource AncestorType=Window}}">
                                    <TextBlock Text="⎘  Copy IP"/>
                                </Button>
                            </Grid>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </Grid>

            <!-- ═══ STATUS BAR ═══ -->
            <Border Grid.Row="5" Background="#0A0A16" CornerRadius="0,0,10,10"
                    BorderThickness="0,1,0,0" BorderBrush="#14141E">
                <Grid Margin="14,0">
                    <TextBlock Text="{Binding StatusText}" FontFamily="Segoe UI" FontSize="10"
                               Foreground="#33334A" VerticalAlignment="Center"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
